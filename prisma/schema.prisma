generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  passwordHash String
  role         String       @default("APPLICANT")
  createdAt    DateTime     @default(now())
  application  Application?
}

model Application {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  applicantType String
  childName     String?
  childGrade    String?
  studentGrade  String?
  comboId       String
  combo         UNTCombo  @relation(fields: [comboId], references: [id])
  language      String
  hearAboutUs   String?
  message       String?
  agreedToExam  Boolean   @default(false)
  status        String    @default("PENDING")
  examDate      DateTime?
  adminNotes    String?
  createdAt     DateTime  @default(now())
}

model Teacher {
  id         String   @id @default(cuid())
  name       String
  subject    String
  experience Int
  bio        String
  photoUrl   String?
  createdAt  DateTime @default(now())
}

model UNTCombo {
  id              String        @id @default(cuid())
  name            String
  nameKz          String?
  subjects        String
  subjectsKz      String?
  professions     String
  professionsKz   String?
  description     String
  descriptionKz   String?
  difficulty      String
  difficultyKz    String?
  spotsTotal      Int           @default(20)
  spotsFilled     Int           @default(0)
  applications    Application[]
}

model NewsPost {
  id          String   @id @default(cuid())
  title       String
  titleKz     String?
  content     String
  contentKz   String?
  imageUrl    String?
  publishedAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}
